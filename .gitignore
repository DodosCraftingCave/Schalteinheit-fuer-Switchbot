# Firmware-Quellcode bleibt privat — nur die kompilierte .bin wird
# unter firmware/ veröffentlicht. main.cpp und platformio.ini enthalten
# die eigentliche Produkt-Firmware und sind KEIN Open-Source-Bestandteil.
main.cpp
platformio.ini
/src/
/.pio/
/lib/
/include/

# PlatformIO Build-Artefakte, falls das Projekt versehentlich aus dem
# gleichen Ordner heraus initialisiert wird
.pio
.vscode/.browse.c_cpp.db*
.vscode/c_cpp_properties.json
.vscode/launch.json
.vscode/ipch

# Python
__pycache__/
*.pyc
dist/
build/
*.spec

# Betriebssystem
.DS_Store
Thumbs.db
